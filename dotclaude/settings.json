{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Grep",
      "Cat",
      "Sed",
      "Read(~/work/*)",
      "Read(~/newstack/*)",
      "Read(~/books/*)",
      "Read(~/projects/*)",
      "Read(/tmp/*)",
      "Bash(xargs *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(awk *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(du *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(jq *)",
      "Bash(java -version *)",
      "Bash(java -version)",
      "Bash(mvn -version *)",
      "Bash(mvn -version)",
      "Bash(mvn test *)",
      "Bash(mvn clean *)",
      "Bash(mvn compile *)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git remote *)",
      "Bash(git remote)",
      "Bash(git tag *)",
      "Bash(git tag)",
      "Bash(git stash list *)",
      "Bash(git stash list)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(git rev-parse *)",
      "Bash(git config --get *)",
      "Bash(git config --list *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh issue status)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr status)",
      "Bash(gh pr diff *)",
      "Bash(gh pr check *)",
      "Bash(gh pr checks *)",
      "Bash(gh label list *)",
      "Bash(gh label view *)",
      "Bash(gh run list *)",
      "Bash(gh run list)",
      "Bash(gh run view *)",
      "Bash(gh repo view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh search *)",
      "Bash(gh api *)",
      "Bash(ls:*)",
      "Bash(stack-brain:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(gh pr:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/work",
      "~/newstack",
      "~/books",
      "~/projects"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/check-constraints.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/flash-tab.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/reset-tab.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "gopls-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-code-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754089543064
  }
}
